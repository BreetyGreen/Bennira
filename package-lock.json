{
  "name": "bennira",
  "version": "0.1.0-alpha.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "bennira",
      "version": "0.1.0-alpha.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "bin": {
        "bennira": "packages/cli/src/index.mjs"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@bennira/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@bennira/core": {
      "resolved": "packages/core",
      "link": true
    },
    "packages/cli": {
      "name": "@bennira/cli",
      "version": "0.1.0-alpha.0",
      "license": "MIT",
      "dependencies": {
        "@bennira/core": "0.1.0-alpha.0"
      },
      "bin": {
        "bennira": "src/index.mjs"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/core": {
      "name": "@bennira/core",
      "version": "0.1.0-alpha.0",
      "license": "MIT",
      "engines": {
        "node": ">=20"
      }
    }
  }
}
